APP_ENV=production
APP_URL=https://your-domain.example

# Server-only secrets (keep in /home/<cpanel-user>/.env, not in public_html)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=REPLACE_WITH_CPANEL_PREFIX_DB_NAME
DB_USER=REPLACE_WITH_CPANEL_DB_USER
DB_PASS=REPLACE_WITH_CPANEL_DB_PASSWORD
DB_CHARSET=utf8mb4
AUTH_TOKEN_TTL_HOURS=24

# Optional CORS allowlist for API gateway
CORS_ALLOW_ORIGIN=https://your-domain.example

# Public runtime config injected by runtime-config.php
PUBLIC_AUTH_FALLBACK_API_BASE=
PUBLIC_DEFAULT_API_BASE=
PUBLIC_DISABLE_LIVE_SYNC=false
PUBLIC_RUNTIME_MODE=mysql

# Notification providers (optional)
# MAILKETING_API_URL=https://api.mailketing.co.id/api/v1/send
# MAILKETING_API_KEY=
# MAILKETING_FROM_NAME=MATIQ
# MAILKETING_SENDER=
# STARSENDER_API_URL=https://api.starsender.online/api/send
# STARSENDER_API_KEY=
# STARSENDER_TIMEOUT_MS=15000

# OpenAI OAuth (optional - for browser-based OAuth login)
# Register at https://platform.openai.com/settings (Organization -> OAuth apps)
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_CLIENT_SECRET=

# Password reset secret (generate with: openssl rand -hex 32)
# PASSWORD_RESET_SECRET=
