APP_ENV=production
APP_URL=https://your-domain.example

# Server-only secrets (keep in /home/<cpanel-user>/.env, not in public_html)
GAS_WEB_APP_URL=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec
DB_TARGET_SHEET_ID=REPLACE_WITH_SHEET_ID
INTERNAL_API_TOKEN=REPLACE_WITH_INTERNAL_API_TOKEN

# Optional CORS allowlist for API gateway
CORS_ALLOW_ORIGIN=https://your-domain.example

# Public runtime config injected by runtime-config.php
PUBLIC_GAS_WEB_APP_URL=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec
PUBLIC_DB_TARGET_SHEET_ID=REPLACE_WITH_SHEET_ID
PUBLIC_AUTH_FALLBACK_API_BASE=
PUBLIC_DEFAULT_API_BASE=
PUBLIC_DISABLE_LIVE_SYNC=false

# Notification providers (set in GAS Script Properties for live runtime)
# MAILKETING_API_URL=
# MAILKETING_API_KEY=
# MAILKETING_SENDER=
# STARSENDER_API_URL=
# STARSENDER_API_KEY=
# STARSENDER_DEVICE_ID=
